@inherits LayoutComponentBase

<MudThemeProvider Theme="@theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6">HomeApp</MudText>
    </MudAppBar>

    <MudDrawer @bind-Open="drawerOpen" Elevation="2">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Menu</MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool drawerOpen = true;

    private MudTheme theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#6B2737",
            PrimaryContrastText = "#FDFAF6",
            Secondary = "#B8860B",
            SecondaryContrastText = "#FDFAF6",
            Background = "#FAF6F0",
            Surface = "#FFFFFF",
            AppbarBackground = "#6B2737",
            AppbarText = "#FDFAF6",
            DrawerBackground = "#F5EDE3",
            DrawerText = "#3D1F26",
            DrawerIcon = "#6B2737",
            TextPrimary = "#2C1518",
            TextSecondary = "#7A5560",
            ActionDefault = "#9E6470",
        }
    };

    private void ToggleDrawer()
    {
        drawerOpen = !drawerOpen;
    }
}
