@inject ISender Sender

<MudDialog>
    <DialogContent>
        <MudForm @ref="form">
            <MudTextField @bind-Value="name" Label="Name" Required="true" Class="mb-4" />
            <MudDatePicker @bind-Date="birthday" Label="Birthday" DateFormat="yyyy-MM-dd"
                           MaxDate="DateTime.Today" Class="mb-4" Clearable="true" />
            <MudTextField @bind-Value="phoneNumber" Label="Phone Number" Class="mb-4" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public FamilyMemberDto Member { get; set; } = null!;

    private MudForm form = null!;
    private string name = string.Empty;
    private DateTime? birthday;
    private string? phoneNumber;

    protected override void OnInitialized()
    {
        name = Member.Name;
        birthday = Member.Birthday.HasValue ? Member.Birthday.Value.ToDateTime(TimeOnly.MinValue) : null;
        phoneNumber = Member.PhoneNumber;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await form.ValidateAsync();
        if (!form.IsValid) return;

        DateOnly? birthdayValue = birthday.HasValue ? DateOnly.FromDateTime(birthday.Value) : null;
        await Sender.Send(new UpdateFamilyMemberCommand(Member.Id, name, birthdayValue, phoneNumber));
        MudDialog.Close(DialogResult.Ok(true));
    }
}
