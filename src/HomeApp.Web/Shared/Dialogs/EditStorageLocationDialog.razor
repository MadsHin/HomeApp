@inject ISender Sender

<MudDialog>
    <DialogContent>
        <MudForm @ref="form">
            <MudTextField @bind-Value="name" Label="Name" Required="true" Class="mb-4" />
            <MudTextField @bind-Value="notes" Label="Notes" Lines="2" Class="mb-4" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public StorageLocationDto Location { get; set; } = null!;

    private MudForm form = null!;
    private string name = string.Empty;
    private string? notes;

    protected override void OnInitialized()
    {
        name = Location.Name;
        notes = Location.Notes;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await form.ValidateAsync();
        if (!form.IsValid) return;

        await Sender.Send(new UpdateStorageLocationCommand(Location.Id, name, notes));
        MudDialog.Close(DialogResult.Ok(true));
    }
}
