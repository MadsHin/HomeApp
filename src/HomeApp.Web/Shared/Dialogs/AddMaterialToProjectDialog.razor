@inject ISender Sender

<MudDialog>
    <DialogContent>
        <MudForm @ref="form">
            <MudSelect T="Guid?" Value="selectedMaterialId" ValueChanged="OnMaterialSelected"
                       Label="Material" Required="true" Class="mb-2">
                @foreach (MaterialDto m in materials)
                {
                    <MudSelectItem Value="@((Guid?)m.Id)">
                        @if (m.Icon is not null)
                        {
                            <MudIcon Icon="@m.Icon" Size="Size.Small" Class="mr-1" />
                        }
                        @m.Name
                    </MudSelectItem>
                }
            </MudSelect>

            @if (selectedMaterial is not null)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
                    Currently in stock:
                    @if (selectedMaterial.Quantity.HasValue)
                    {
                        <strong> @selectedMaterial.Quantity.Value.ToString("G29") @selectedMaterial.Unit</strong>
                    }
                    else
                    {
                        <span> not tracked</span>
                    }
                </MudText>
            }

            <MudNumericField @bind-Value="quantityNeeded"
                             Label="@($"Quantity needed{(selectedMaterial?.Unit is not null ? $" ({selectedMaterial.Unit})" : string.Empty)}")"
                             Min="0" Class="mb-4" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">Add</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid ProjectId { get; set; }

    private MudForm form = null!;
    private Guid? selectedMaterialId;
    private decimal? quantityNeeded;
    private List<MaterialDto> materials = [];
    private MaterialDto? selectedMaterial;

    protected override async Task OnInitializedAsync()
    {
        materials = await Sender.Send(new GetMaterialsQuery());
    }

    private void OnMaterialSelected(Guid? id)
    {
        selectedMaterialId = id;
        selectedMaterial = id.HasValue ? materials.FirstOrDefault(m => m.Id == id.Value) : null;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await form.ValidateAsync();
        if (!form.IsValid || selectedMaterialId is null) return;

        await Sender.Send(new AddMaterialToProjectCommand(ProjectId, selectedMaterialId.Value, quantityNeeded));
        MudDialog.Close(DialogResult.Ok(true));
    }
}
