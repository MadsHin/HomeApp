@using System.Reflection

<MudDialog>
    <DialogContent>
        <MudTextField Value="@search" ValueChanged="@((string s) => OnSearch(s))"
                      Label="Search icons" Placeholder="e.g. construction, home, tool, paint…"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" DebounceInterval="150" Class="mb-3" />

        @if (search.Length < 2)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">Type at least 2 characters to search</MudText>
        }
        else if (filteredIcons.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">No icons found for "@search"</MudText>
        }
        else
        {
            <div style="height:360px;overflow-y:auto">
                <MudGrid Spacing="1">
                    @foreach ((string name, string value) in filteredIcons)
                    {
                        bool isSelected = name == selectedName;
                        <MudItem xs="2" Style="text-align:center">
                            <MudTooltip Text="@name" Placement="Placement.Top">
                                <div style="@(isSelected ? "border-radius:8px;background:rgba(107,39,55,0.12)" : string.Empty)">
                                    <MudIconButton Icon="@value"
                                                   Color="@(isSelected ? Color.Primary : Color.Default)"
                                                   OnClick="@(() => selectedName = name)" />
                                </div>
                            </MudTooltip>
                        </MudItem>
                    }
                </MudGrid>
            </div>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                @filteredIcons.Count result@(filteredIcons.Count == 1 ? string.Empty : "s")
                @(filteredIcons.Count == MaxResults ? $" (top {MaxResults})" : string.Empty)
            </MudText>
        }
    </DialogContent>
    <DialogActions>
        @if (CurrentIcon is not null)
        {
            <MudButton Color="Color.Error" StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearIcon">
                Remove icon
            </MudButton>
        }
        <MudSpacer />
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Disabled="@(selectedName is null)" OnClick="Submit">Select</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public string? CurrentIcon { get; set; }

    private const int MaxResults = 60;

    private string search = string.Empty;
    private string? selectedName;
    private List<(string Name, string Value)> filteredIcons = [];

    private static readonly List<(string Name, string Value)> AllIcons =
        typeof(Icons.Material.Filled)
            .GetFields(BindingFlags.Public | BindingFlags.Static)
            .Where(f => f.FieldType == typeof(string))
            .Select(f => (Name: f.Name, Value: (string)f.GetValue(null)!))
            .OrderBy(i => i.Name)
            .ToList();

    private static readonly Dictionary<string, string> ValueToName =
        AllIcons
            .GroupBy(i => i.Value)
            .ToDictionary(g => g.Key, g => g.First().Name);

    protected override void OnInitialized()
    {
        if (CurrentIcon is not null)
            ValueToName.TryGetValue(CurrentIcon, out selectedName);
    }

    private void OnSearch(string value)
    {
        search = value;
        filteredIcons = search.Length < 2
            ? []
            : AllIcons
                .Where(i => i.Name.Contains(search, StringComparison.OrdinalIgnoreCase))
                .Take(MaxResults)
                .ToList();
    }

    private void ClearIcon() => MudDialog.Close(DialogResult.Ok<string?>(null));
    private void Cancel() => MudDialog.Cancel();
    private void Submit() => MudDialog.Close(
        DialogResult.Ok(filteredIcons.FirstOrDefault(i => i.Name == selectedName).Value
                        ?? AllIcons.FirstOrDefault(i => i.Name == selectedName).Value));
}
