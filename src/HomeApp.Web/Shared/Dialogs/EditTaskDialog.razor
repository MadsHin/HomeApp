@inject ISender Sender

<MudDialog>
    <DialogContent>
        <MudForm @ref="form">
            <MudTextField @bind-Value="title" Label="Title" Required="true" Class="mb-4" />
            <MudTextField @bind-Value="description" Label="Description" Lines="3" Class="mb-4" />
            <MudDatePicker @bind-Date="dueDateNullable" Label="Due Date" Class="mb-4" />
            <MudSelect T="Recurrence" @bind-Value="recurrence" Label="Recurrence" Class="mb-4">
                @foreach (Recurrence r in Enum.GetValues<Recurrence>())
                {
                    <MudSelectItem Value="r">@r</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="Guid?" @bind-Value="assignedMemberId" Label="Assign to" Clearable="true" Class="mb-4">
                @foreach (FamilyMemberDto member in familyMembers)
                {
                    <MudSelectItem Value="@((Guid?)member.Id)">@member.Name</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public HouseholdTaskDto Task { get; set; } = null!;

    private MudForm form = null!;
    private string title = string.Empty;
    private string? description;
    private DateTime? dueDateNullable;
    private Recurrence recurrence = Recurrence.None;
    private Guid? assignedMemberId;
    private List<FamilyMemberDto> familyMembers = [];

    protected override async Task OnInitializedAsync()
    {
        familyMembers = await Sender.Send(new GetFamilyMembersQuery());
        title = Task.Title;
        description = Task.Description;
        dueDateNullable = Task.DueDate.HasValue ? Task.DueDate.Value.ToDateTime(TimeOnly.MinValue) : null;
        recurrence = Task.Recurrence;
        assignedMemberId = Task.AssignedMemberId;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await form.ValidateAsync();
        if (!form.IsValid) return;

        DateOnly? dueDate = dueDateNullable.HasValue
            ? DateOnly.FromDateTime(dueDateNullable.Value)
            : null;

        await Sender.Send(new UpdateHouseholdTaskCommand(Task.Id, title, description, dueDate, recurrence, assignedMemberId));
        MudDialog.Close(DialogResult.Ok(true));
    }
}
