@page "/gallery"
@inject ISender Sender

<MudText Typo="Typo.h4" Class="mb-6">Photo Gallery</MudText>

@if (photosByProject is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (photosByProject.Count == 0)
{
    <MudText Color="Color.Secondary">No photos uploaded yet.</MudText>
}
else
{
    @foreach (var group in photosByProject)
    {
        <MudText Typo="Typo.h6" Class="mb-3">
            <MudLink Href="@($"/home-projects/{group.Key.Id}")" Color="Color.Primary">
                @group.Key.Title
            </MudLink>
        </MudText>

        <MudGrid Class="mb-8">
            @foreach (PhotoDto photo in group.Value)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="2">
                        <MudCardMedia Image="@($"/uploads/photos/{photo.StoredFileName}")"
                                      Height="180" />
                        @if (photo.Caption is not null)
                        {
                            <MudCardContent Class="pa-2">
                                <MudText Typo="Typo.caption">@photo.Caption</MudText>
                            </MudCardContent>
                        }
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
}

@code {
    private Dictionary<(Guid Id, string Title), List<PhotoDto>>? photosByProject;

    protected override async Task OnInitializedAsync()
    {
        List<PhotoDto> all = await Sender.Send(new GetAllPhotosQuery());
        photosByProject = all
            .GroupBy(p => (p.HomeProjectId, p.ProjectTitle))
            .ToDictionary(
                g => (g.Key.HomeProjectId, g.Key.ProjectTitle),
                g => g.ToList());
    }
}
