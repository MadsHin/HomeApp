@page "/"
@inject ISender Sender
@inject IDialogService DialogService

<PageTitle>HomeApp</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">@Greeting</MudText>
<MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">@DateTime.Today.ToString("dddd, MMMM d")</MudText>

<!-- Summary cards -->
<MudGrid Class="mb-8">
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="@(OverdueCount > 0 ? Color.Error : Color.Success)" Size="Size.Large" Class="mb-2" />
            <MudText Typo="Typo.h3" Color="@(OverdueCount > 0 ? Color.Error : Color.Default)">@OverdueCount</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Overdue Tasks</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.Today" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
            <MudText Typo="Typo.h3">@DueThisWeekCount</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Due This Week</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.Construction" Color="Color.Warning" Size="Size.Large" Class="mb-2" />
            <MudText Typo="Typo.h3">@ActiveProjectCount</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Active Projects</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Info" Size="Size.Large" Class="mb-2" />
            <MudText Typo="Typo.h3">@(familyMembers?.Count ?? 0)</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Family Members</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<!-- Tasks and Projects -->
<MudGrid Class="mb-8">

    <!-- Overdue tasks -->
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" Class="mr-2" />
                Overdue
            </MudText>
            @if (overdueTasks is null)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (overdueTasks.Count == 0)
            {
                <MudText Color="Color.Success">Nothing overdue — great job!</MudText>
            }
            else
            {
                <MudList T="HouseholdTaskDto" Dense="true">
                    @foreach (HouseholdTaskDto task in overdueTasks)
                    {
                        <MudListItem>
                            <div class="d-flex justify-space-between align-center">
                                <div>
                                    <MudText Typo="Typo.body1">@task.Title</MudText>
                                    @if (task.DueDate.HasValue)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Error">Due @task.DueDate</MudText>
                                    }
                                </div>
                                <MudIconButton Icon="@Icons.Material.Filled.CheckCircleOutline"
                                               Color="Color.Success"
                                               Size="Size.Small"
                                               OnClick="() => CompleteTask(task.Id)" />
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudPaper>
    </MudItem>

    <!-- Due this week -->
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Color="Color.Primary" Class="mr-2" />
                Due This Week
            </MudText>
            @if (allTasks is null)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (DueThisWeek.Count == 0)
            {
                <MudText Color="Color.Secondary">No tasks due this week.</MudText>
            }
            else
            {
                <MudList T="HouseholdTaskDto" Dense="true">
                    @foreach (HouseholdTaskDto task in DueThisWeek)
                    {
                        <MudListItem>
                            <div class="d-flex justify-space-between align-center">
                                <div>
                                    <MudText Typo="Typo.body1">@task.Title</MudText>
                                    @if (task.DueDate.HasValue)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Due @task.DueDate</MudText>
                                    }
                                </div>
                                <MudIconButton Icon="@Icons.Material.Filled.CheckCircleOutline"
                                               Color="Color.Success"
                                               Size="Size.Small"
                                               OnClick="() => CompleteTask(task.Id)" />
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

<!-- Tools away + Expenses -->
<MudGrid Class="mb-8">

    @if (LentOutTools.Count > 0 || BorrowedTools.Count > 0)
    {
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-4" Elevation="2" Style="height:100%">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Handyman" Class="mr-2" />
                        Tools away
                    </MudText>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/tools" Size="Size.Small">
                        All tools
                    </MudButton>
                </MudStack>

                @if (LentOutTools.Count > 0)
                {
                    <MudText Typo="Typo.caption" Color="Color.Warning" Class="mb-1">LENT OUT</MudText>
                    @foreach (ToolDto t in LentOutTools)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
                            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Warning" />
                            <MudText Typo="Typo.body2">
                                <strong>@t.Name</strong>
                                @if (t.StatusNote is not null)
                                {
                                    <span class="mud-secondary-text"> → @t.StatusNote</span>
                                }
                            </MudText>
                        </MudStack>
                    }
                }

                @if (BorrowedTools.Count > 0)
                {
                    <MudText Typo="Typo.caption" Color="Color.Info" Class="@(LentOutTools.Count > 0 ? "mt-3 mb-1" : "mb-1")">BORROWED</MudText>
                    @foreach (ToolDto t in BorrowedTools)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
                            <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Color="Color.Info" />
                            <MudText Typo="Typo.body2">
                                <strong>@t.Name</strong>
                                @if (t.StatusNote is not null)
                                {
                                    <span class="mud-secondary-text"> from @t.StatusNote</span>
                                }
                            </MudText>
                        </MudStack>
                    }
                }
            </MudPaper>
        </MudItem>
    }

    <MudItem xs="12" md="@(LentOutTools.Count > 0 || BorrowedTools.Count > 0 ? 7 : 12)">
        <MudPaper Class="pa-4" Elevation="2" Style="height:100%">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.Receipt" Class="mr-2" />
                    Expenses
                </MudText>
                <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                    <MudButton Color="@(expensePeriod == ExpensePeriod.ThisMonth ? Color.Primary : Color.Default)"
                               OnClick="@(() => expensePeriod = ExpensePeriod.ThisMonth)">Month</MudButton>
                    <MudButton Color="@(expensePeriod == ExpensePeriod.Last3Months ? Color.Primary : Color.Default)"
                               OnClick="@(() => expensePeriod = ExpensePeriod.Last3Months)">3 months</MudButton>
                    <MudButton Color="@(expensePeriod == ExpensePeriod.ThisYear ? Color.Primary : Color.Default)"
                               OnClick="@(() => expensePeriod = ExpensePeriod.ThisYear)">Year</MudButton>
                    <MudButton Color="@(expensePeriod == ExpensePeriod.AllTime ? Color.Primary : Color.Default)"
                               OnClick="@(() => expensePeriod = ExpensePeriod.AllTime)">All time</MudButton>
                </MudButtonGroup>
            </MudStack>

            @if (allExpenses is null)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (FilteredExpenses.Count == 0)
            {
                <MudText Color="Color.Secondary">No expenses in this period.</MudText>
            }
            else
            {
                <MudText Typo="Typo.h4" Class="mb-3">@FilteredExpenses.Sum(e => e.Amount).ToString("N0") kr</MudText>
                @foreach (var group in FilteredExpenses.GroupBy(e => e.ProjectTitle).OrderByDescending(g => g.Sum(e => e.Amount)))
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-1">
                        <MudText Typo="Typo.body2">@group.Key</MudText>
                        <MudText Typo="Typo.body2">@group.Sum(e => e.Amount).ToString("N0") kr</MudText>
                    </MudStack>
                }
            }
        </MudPaper>
    </MudItem>

</MudGrid>

<!-- Active projects -->
<MudText Typo="Typo.h6" Class="mb-3">
    <MudIcon Icon="@Icons.Material.Filled.Construction" Class="mr-2" />
    Active Projects
</MudText>
@if (projects is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (ActiveProjects.Count == 0)
{
    <MudText Color="Color.Secondary" Class="mb-6">No active projects.</MudText>
}
else
{
    <MudGrid Class="mb-8">
        @foreach (HomeProjectDto project in ActiveProjects)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@project.Title</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip T="string" Color="@StatusColor(project.Status)" Size="Size.Small">@project.Status</MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    @if (!string.IsNullOrWhiteSpace(project.Description))
                    {
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@project.Description</MudText>
                        </MudCardContent>
                    }
                    @if (project.Budget.HasValue)
                    {
                        <MudCardContent>
                            <MudText Typo="Typo.caption">Budget: @project.Budget.Value.ToString("N0") kr</MudText>
                        </MudCardContent>
                    }
                    <MudCardActions>
                        <MudButton Variant="Variant.Text" Color="Color.Primary"
                                   Href="@($"/home-projects/{project.Id}")">
                            View
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

<!-- Quick actions -->
<MudPaper Class="pa-4" Elevation="1">
    <MudText Typo="Typo.h6" Class="mb-3">Quick Actions</MudText>
    <MudStack Row="true" Spacing="3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenAddTaskDialog">
            Add Task
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.AddHome"
                   OnClick="OpenAddProjectDialog">
            New Project
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    private List<HouseholdTaskDto>? overdueTasks;
    private List<HouseholdTaskDto>? allTasks;
    private List<HomeProjectDto>? projects;
    private List<FamilyMemberDto>? familyMembers;
    private List<ToolDto>? tools;
    private List<AllExpenseDto>? allExpenses;
    private ExpensePeriod expensePeriod = ExpensePeriod.ThisMonth;

    private enum ExpensePeriod { ThisMonth, Last3Months, ThisYear, AllTime }

    private string Greeting => DateTime.Now.Hour switch
    {
        < 12 => "Good morning",
        < 17 => "Good afternoon",
        _    => "Good evening"
    };

    private int OverdueCount => overdueTasks?.Count ?? 0;
    private int DueThisWeekCount => DueThisWeek.Count;
    private int ActiveProjectCount => ActiveProjects.Count;

    private List<HouseholdTaskDto> DueThisWeek
    {
        get
        {
            if (allTasks is null) return [];
            DateOnly today = DateOnly.FromDateTime(DateTime.Today);
            DateOnly weekEnd = today.AddDays(7);
            return allTasks
                .Where(t => !t.IsCompleted && t.DueDate.HasValue && t.DueDate.Value >= today && t.DueDate.Value <= weekEnd)
                .ToList();
        }
    }

    private List<HomeProjectDto> ActiveProjects => projects
        ?.Where(p => p.Status is ProjectStatus.Planning or ProjectStatus.InProgress)
        .ToList() ?? [];

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll()
    {
        overdueTasks = await Sender.Send(new GetOverdueTasksQuery());
        allTasks = await Sender.Send(new GetHouseholdTasksQuery());
        projects = await Sender.Send(new GetHomeProjectsQuery());
        familyMembers = await Sender.Send(new GetFamilyMembersQuery());
        tools = await Sender.Send(new GetToolsQuery());
        allExpenses = await Sender.Send(new GetAllExpensesQuery());
    }

    private List<ToolDto> LentOutTools => tools?.Where(t => t.Status == ToolStatus.LentOut).ToList() ?? [];
    private List<ToolDto> BorrowedTools => tools?.Where(t => t.Status == ToolStatus.Borrowed).ToList() ?? [];

    private List<AllExpenseDto> FilteredExpenses
    {
        get
        {
            if (allExpenses is null) return [];
            DateOnly cutoff = expensePeriod switch
            {
                ExpensePeriod.ThisMonth   => DateOnly.FromDateTime(new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1)),
                ExpensePeriod.Last3Months => DateOnly.FromDateTime(DateTime.Today.AddMonths(-3)),
                ExpensePeriod.ThisYear    => new DateOnly(DateTime.Today.Year, 1, 1),
                _                         => DateOnly.MinValue
            };
            return allExpenses.Where(e => e.Date >= cutoff).ToList();
        }
    }

    private async Task CompleteTask(Guid id)
    {
        await Sender.Send(new CompleteHouseholdTaskCommand(id));
        await LoadAll();
    }

    private async Task OpenAddTaskDialog()
    {
        IDialogReference dialog = await DialogService.ShowAsync<AddTaskDialog>("Add Task");
        DialogResult? result = await dialog.Result;
        if (result is { Canceled: false }) await LoadAll();
    }

    private async Task OpenAddProjectDialog()
    {
        IDialogReference dialog = await DialogService.ShowAsync<AddProjectDialog>("New Project");
        DialogResult? result = await dialog.Result;
        if (result is { Canceled: false }) await LoadAll();
    }

    private static Color StatusColor(ProjectStatus status) => status switch
    {
        ProjectStatus.Planning    => Color.Info,
        ProjectStatus.InProgress  => Color.Warning,
        ProjectStatus.OnHold      => Color.Default,
        ProjectStatus.Completed   => Color.Success,
        ProjectStatus.Cancelled   => Color.Error,
        _                         => Color.Default
    };
}
