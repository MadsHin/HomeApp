@page "/family-members"
@inject ISender Sender
@inject IDialogService DialogService

<MudText Typo="Typo.h4" Class="mb-4">Family Members</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialog" Class="mb-4">
    Add Member
</MudButton>

@if (members is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudTable T="FamilyMemberDto" Items="members" Hover="true" Striped="true" Dense="true"
              SortLabel="Sort By" Filter="new Func<FamilyMemberDto, bool>(FilterFunc)">
        <ToolBarContent>
            <MudSpacer />
            <MudTextField @bind-Value="searchString" Placeholder="Search" Clearable="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<FamilyMemberDto, object>(x => x.Name)">Name</MudTableSortLabel></MudTh>
            <MudTh Class="hide-mobile"><MudTableSortLabel SortBy="new Func<FamilyMemberDto, object>(x => x.Birthday ?? DateOnly.MaxValue)">Birthday</MudTableSortLabel></MudTh>
            <MudTh Class="hide-mobile">Phone</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd Class="hide-mobile">
                @if (context.Birthday.HasValue)
                {
                    <MudText>@context.Birthday.Value.ToString("yyyy-MM-dd") <MudText Inline="true" Typo="Typo.caption" Color="Color.Secondary">(@ComputeAge(context.Birthday) yrs)</MudText></MudText>
                }
                else
                {
                    <MudText Color="Color.Secondary">—</MudText>
                }
            </MudTd>
            <MudTd Class="hide-mobile">@(context.PhoneNumber ?? "—")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" title="Edit"
                               OnClick="@(() => OpenEditDialog(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" title="Delete"
                               OnClick="@(() => DeleteMember(context.Id))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<FamilyMemberDto>? members;
    private string searchString = "";

    private static int ComputeAge(DateOnly? birthday)
    {
        if (birthday is null) return 0;
        DateOnly today = DateOnly.FromDateTime(DateTime.Today);
        int age = today.Year - birthday.Value.Year;
        if (birthday.Value.AddYears(age) > today) age--;
        return age;
    }

    private bool FilterFunc(FamilyMemberDto m)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        if (m.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (m.PhoneNumber?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (m.Birthday.HasValue && m.Birthday.Value.ToString("yyyy-MM-dd").Contains(searchString)) return true;
        return false;
    }

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        members = await Sender.Send(new GetFamilyMembersQuery());
    }

    private async Task OpenAddDialog()
    {
        IDialogReference d = await DialogService.ShowAsync<AddFamilyMemberDialog>("Add Family Member");
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task OpenEditDialog(FamilyMemberDto member)
    {
        DialogParameters<EditFamilyMemberDialog> parameters = new();
        parameters.Add(x => x.Member, member);
        IDialogReference d = await DialogService.ShowAsync<EditFamilyMemberDialog>("Edit Family Member", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task DeleteMember(Guid id)
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync("Delete Member", "Are you sure you want to delete this family member?", yesText: "Delete", cancelText: "Cancel");
        if (confirmed == true)
        {
            await Sender.Send(new DeleteFamilyMemberCommand(id));
            await Load();
        }
    }
}
