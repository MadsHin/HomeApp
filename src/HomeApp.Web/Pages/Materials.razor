@page "/materials"
@inject ISender Sender
@inject IDialogService DialogService

<MudText Typo="Typo.h4" Class="mb-4">Materials Inventory</MudText>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap" Class="mb-4">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenAddDialog">
        Add Material
    </MudButton>
    <MudSelect @bind-Value="locationFilter" Label="Location" Dense="true" Margin="Margin.Dense"
               Clearable="true" Style="min-width:180px">
        @foreach (StorageLocationDto loc in locations)
        {
            <MudSelectItem Value="@((Guid?)loc.Id)">@loc.Name</MudSelectItem>
        }
    </MudSelect>
    <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
        <MudIconButton Icon="@Icons.Material.Filled.GridView"
                       Color="@(gridView ? Color.Primary : Color.Default)"
                       OnClick="@(() => gridView = true)" />
        <MudIconButton Icon="@Icons.Material.Filled.TableRows"
                       Color="@(gridView ? Color.Default : Color.Primary)"
                       OnClick="@(() => gridView = false)" />
    </MudButtonGroup>
</MudStack>

@if (materials is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (materials.Count == 0)
{
    <MudText Typo="Typo.body1" Color="Color.Secondary">No materials yet. Add one to start your inventory.</MudText>
}
else if (gridView)
{
    <MudGrid>
        @foreach (MaterialDto m in FilteredMaterials)
        {
            <MudItem xs="12" sm="6" md="4"
                     draggable="true"
                     @ondragstart="@(() => dragging = m.Id)"
                     @ondragend="@(() => { dragging = null; hovering = null; })"
                     @ondragenter="@(() => hovering = m.Id)"
                     @ondragover:preventDefault="true"
                     @ondrop="@(() => Drop(m.Id))">
                <MudCard Elevation="2" Style="@($"height:100%;{CardStyle(m.Id)}")">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            @if (m.Icon is not null)
                            {
                                <IconDisplay Icon="@m.Icon" Color="Color.Primary" Size="Size.Large" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Default" Size="Size.Large" />
                            }
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@m.Name</MudText>
                            @if (m.StorageLocationName is not null)
                            {
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Warehouse" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@m.StorageLocationName</MudText>
                                </MudStack>
                            }
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                           OnClick="@(() => OpenEditDialog(m))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                           OnClick="@(() => DeleteMaterial(m.Id))" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body1">
                                <strong>@(m.Quantity.HasValue ? m.Quantity.Value.ToString("G29") : "—")</strong>
                                @(m.Unit is not null ? $" {m.Unit}" : string.Empty)
                            </MudText>
                            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                                <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                               Disabled="@(m.Quantity is null or 0)"
                                               OnClick="@(() => Adjust(m, -1))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Add"
                                               OnClick="@(() => Adjust(m, 1))" />
                            </MudButtonGroup>
                        </MudStack>
                        @if (m.Notes is not null)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">@m.Notes</MudText>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}
else
{
    <MudTable T="MaterialDto" Items="FilteredMaterials" Hover="true" Elevation="2"
              SortLabel="Sort By" Filter="new Func<MaterialDto, bool>(FilterFunc)">
        <ToolBarContent>
            <MudSpacer />
            <MudTextField @bind-Value="searchString" Placeholder="Search" Clearable="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<MaterialDto, object>(x => x.Name)">Material</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<MaterialDto, object>(x => x.StorageLocationName ?? string.Empty)">Location</MudTableSortLabel></MudTh>
            <MudTh Style="text-align:right"><MudTableSortLabel SortBy="new Func<MaterialDto, object>(x => x.Quantity ?? 0)">Quantity</MudTableSortLabel></MudTh>
            <MudTh />
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    @if (context.Icon is not null)
                    {
                        <IconDisplay Icon="@context.Icon" Size="Size.Small" Color="Color.Primary" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" Color="Color.Default" />
                    }
                    <MudText>@context.Name</MudText>
                </MudStack>
            </MudTd>
            <MudTd>
                @if (context.StorageLocationName is not null)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Warehouse" Size="Size.Small" Color="Color.Secondary" />
                        <MudText Typo="Typo.body2">@context.StorageLocationName</MudText>
                    </MudStack>
                }
                else
                {
                    <MudText Color="Color.Secondary">—</MudText>
                }
            </MudTd>
            <MudTd Style="text-align:right">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="2">
                    <MudText>
                        @(context.Quantity.HasValue ? context.Quantity.Value.ToString("G29") : "—")
                        @context.Unit
                    </MudText>
                    <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                        <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                       Disabled="@(context.Quantity is null or 0)"
                                       OnClick="@(() => Adjust(context, -1))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Add"
                                       OnClick="@(() => Adjust(context, 1))" />
                    </MudButtonGroup>
                </MudStack>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                               OnClick="@(() => OpenEditDialog(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => DeleteMaterial(context.Id))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<MaterialDto>? materials;
    private List<StorageLocationDto> locations = [];
    private Guid? locationFilter;
    private string searchString = "";
    private bool gridView = false;
    private Guid? dragging;
    private Guid? hovering;

    private List<MaterialDto> FilteredMaterials => locationFilter.HasValue
        ? (materials?.Where(m => m.StorageLocationId == locationFilter).ToList() ?? [])
        : (materials ?? []);

    private bool FilterFunc(MaterialDto m)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        if (m.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (m.StorageLocationName?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (m.Notes?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    }

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        materials = await Sender.Send(new GetMaterialsQuery());
        locations = await Sender.Send(new GetStorageLocationsQuery());
    }

    private string CardStyle(Guid id)
    {
        if (id == dragging)  return "opacity:0.4;cursor:grabbing;transition:opacity 0.15s;";
        if (id == hovering)  return "outline:2px dashed #6B2737;outline-offset:3px;cursor:grab;";
        return "cursor:grab;";
    }

    private async Task Drop(Guid targetId)
    {
        if (dragging is null || dragging == targetId || materials is null) return;

        MaterialDto? draggedItem = materials.FirstOrDefault(m => m.Id == dragging);
        if (draggedItem is null) return;

        int from = materials.IndexOf(draggedItem);
        int to   = materials.IndexOf(materials.First(m => m.Id == targetId));

        materials.RemoveAt(from);
        materials.Insert(to, draggedItem);

        dragging = null;
        hovering = null;

        await Sender.Send(new ReorderMaterialsCommand(materials.Select(m => m.Id).ToList()));
    }

    private async Task Adjust(MaterialDto material, decimal delta)
    {
        await Sender.Send(new AdjustMaterialQuantityCommand(material.Id, delta));
        await Load();
    }

    private async Task OpenAddDialog()
    {
        IDialogReference d = await DialogService.ShowAsync<AddMaterialDialog>("Add Material");
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task OpenEditDialog(MaterialDto material)
    {
        DialogParameters<EditMaterialDialog> parameters = new();
        parameters.Add(x => x.Material, material);
        IDialogReference d = await DialogService.ShowAsync<EditMaterialDialog>("Edit Material", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task DeleteMaterial(Guid id)
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync("Delete Material", "Are you sure you want to delete this material?", yesText: "Delete", cancelText: "Cancel");
        if (confirmed == true)
        {
            await Sender.Send(new DeleteMaterialCommand(id));
            await Load();
        }
    }
}
