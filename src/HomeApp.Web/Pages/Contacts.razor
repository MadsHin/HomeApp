@page "/contacts"
@inject ISender Sender
@inject IDialogService DialogService

<MudText Typo="Typo.h4" Class="mb-4">Contacts</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialog" Class="mb-4">
    Add Contact
</MudButton>

@if (contacts is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudTable T="ContactDto" Items="contacts" Hover="true" Striped="true" Dense="true"
              SortLabel="Sort By" Filter="new Func<ContactDto, bool>(FilterFunc)">
        <ToolBarContent>
            <MudSpacer />
            <MudTextField @bind-Value="searchString" Placeholder="Search" Clearable="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<ContactDto, object>(x => x.Name)">Name</MudTableSortLabel></MudTh>
            <MudTh Class="hide-mobile">Phone</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd Class="hide-mobile">@(context.Phone ?? "—")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" title="Edit"
                               OnClick="@(() => OpenEditDialog(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" title="Delete"
                               OnClick="@(() => DeleteContact(context.Id))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<ContactDto>? contacts;
    private string searchString = "";

    private bool FilterFunc(ContactDto c)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        if (c.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (c.Phone?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    }

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        contacts = await Sender.Send(new GetContactsQuery());
    }

    private async Task OpenAddDialog()
    {
        IDialogReference d = await DialogService.ShowAsync<AddContactDialog>("Add Contact");
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task OpenEditDialog(ContactDto contact)
    {
        DialogParameters<EditContactDialog> parameters = new();
        parameters.Add(x => x.Contact, contact);
        IDialogReference d = await DialogService.ShowAsync<EditContactDialog>("Edit Contact", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task DeleteContact(Guid id)
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync("Delete Contact", "Are you sure you want to delete this contact?", yesText: "Delete", cancelText: "Cancel");
        if (confirmed == true)
        {
            await Sender.Send(new DeleteContactCommand(id));
            await Load();
        }
    }
}
