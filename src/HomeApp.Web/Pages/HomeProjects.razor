@page "/home-projects"
@inject ISender Sender
@inject IDialogService DialogService
@inject NavigationManager Navigation

<MudText Typo="Typo.h4" Class="mb-4">Home Projects</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialog" Class="mb-4">
    New Project
</MudButton>

@if (projects is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudTable T="HomeProjectDto" Items="projects" Hover="true" Striped="true">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Budget</MudTh>
            <MudTh>Start Date</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Title</MudTd>
            <MudTd>
                <MudChip T="string" Color="@StatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
            </MudTd>
            <MudTd>@(context.Budget.HasValue ? $"{context.Budget.Value:N0} kr" : "—")</MudTd>
            <MudTd>@(context.StartDate.HasValue ? context.StartDate.Value.ToString("yyyy-MM-dd") : "—")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Default" title="View Detail"
                               OnClick="@(() => Navigation.NavigateTo($"/home-projects/{context.Id}"))" />
                <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz" Color="Color.Warning" title="Change Status"
                               OnClick="@(() => OpenChangeStatusDialog(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" title="Edit"
                               OnClick="@(() => OpenEditDialog(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" title="Delete"
                               OnClick="@(() => DeleteProject(context.Id))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<HomeProjectDto>? projects;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        projects = await Sender.Send(new GetHomeProjectsQuery());
    }

    private Color StatusColor(ProjectStatus status) => status switch
    {
        ProjectStatus.Planning => Color.Info,
        ProjectStatus.InProgress => Color.Warning,
        ProjectStatus.OnHold => Color.Default,
        ProjectStatus.Completed => Color.Success,
        ProjectStatus.Cancelled => Color.Error,
        _ => Color.Default
    };

    private async Task OpenAddDialog()
    {
        IDialogReference d = await DialogService.ShowAsync<AddProjectDialog>("New Project");
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task OpenEditDialog(HomeProjectDto project)
    {
        DialogParameters<EditProjectDialog> parameters = new();
        parameters.Add(x => x.Project, project);
        IDialogReference d = await DialogService.ShowAsync<EditProjectDialog>("Edit Project", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task OpenChangeStatusDialog(HomeProjectDto project)
    {
        DialogParameters<ChangeStatusDialog> parameters = new();
        parameters.Add(x => x.ProjectId, project.Id);
        parameters.Add(x => x.CurrentStatus, project.Status);
        IDialogReference d = await DialogService.ShowAsync<ChangeStatusDialog>("Change Status", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task DeleteProject(Guid id)
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync("Delete Project", "Are you sure you want to delete this project?", yesText: "Delete", cancelText: "Cancel");
        if (confirmed == true)
        {
            await Sender.Send(new DeleteHomeProjectCommand(id));
            await Load();
        }
    }
}
