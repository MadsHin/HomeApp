@page "/tools"
@inject ISender Sender
@inject IDialogService DialogService

<MudText Typo="Typo.h4" Class="mb-4">Tools</MudText>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap" Class="mb-4">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenAddDialog">
        Add Tool
    </MudButton>
    <MudSelect @bind-Value="locationFilter" Label="Location" Dense="true" Margin="Margin.Dense"
               Clearable="true" Style="min-width:180px">
        @foreach (StorageLocationDto loc in locations)
        {
            <MudSelectItem Value="@((Guid?)loc.Id)">@loc.Name</MudSelectItem>
        }
    </MudSelect>
    <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
        <MudIconButton Icon="@Icons.Material.Filled.GridView"
                       Color="@(gridView ? Color.Primary : Color.Default)"
                       OnClick="@(() => gridView = true)" />
        <MudIconButton Icon="@Icons.Material.Filled.TableRows"
                       Color="@(gridView ? Color.Default : Color.Primary)"
                       OnClick="@(() => gridView = false)" />
    </MudButtonGroup>
</MudStack>

@if (tools is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    @if (tools.Any(t => t.Status == ToolStatus.LentOut))
    {
        <MudAlert Severity="Severity.Warning" Class="mb-5">
            <MudText Typo="Typo.subtitle2" Class="mb-1">
                @tools.Count(t => t.Status == ToolStatus.LentOut) tool@(tools.Count(t => t.Status == ToolStatus.LentOut) == 1 ? " is" : "s are") currently with others
            </MudText>
            @foreach (ToolDto t in tools.Where(t => t.Status == ToolStatus.LentOut))
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                    <MudText Typo="Typo.body2">
                        <strong>@t.Name</strong>
                        @if (t.StatusNote is not null)
                        {
                            <span> — @t.StatusNote</span>
                        }
                    </MudText>
                </MudStack>
            }
        </MudAlert>
    }

    @if (FilteredTools.Count == 0)
    {
        <MudText Typo="Typo.body1" Color="Color.Secondary">
            @(locationFilter.HasValue ? "No tools in this location." : "No tools yet. Add one to start your inventory.")
        </MudText>
    }
    else if (gridView)
    {
        <MudGrid>
            @foreach (ToolDto t in FilteredTools)
            {
                <MudItem xs="12" sm="6" md="4"
                         draggable="true"
                         @ondragstart="@(() => dragging = t.Id)"
                         @ondragend="@(() => { dragging = null; hovering = null; })"
                         @ondragenter="@(() => hovering = t.Id)"
                         @ondragover:preventDefault="true"
                         @ondrop="@(() => Drop(t.Id))">
                    <MudCard Elevation="2" Style="@($"height:100%;{CardStyle(t.Id)}")">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                @if (t.Icon is not null)
                                {
                                    <IconDisplay Icon="@t.Icon" Color="Color.Primary" Size="Size.Large" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Handyman" Color="Color.Default" Size="Size.Large" />
                                }
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">@t.Name</MudText>
                                @if (t.Category is not null)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@t.Category</MudText>
                                }
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                               OnClick="@(() => OpenEditDialog(t))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                               OnClick="@(() => DeleteTool(t.Id))" />
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudChip T="string" Size="Size.Small" Color="@StatusColor(t.Status)">
                                    @StatusLabel(t.Status, t.StatusNote)
                                </MudChip>
                                @if (t.StorageLocationName is not null)
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.Warehouse" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@t.StorageLocationName</MudText>
                                    </MudStack>
                                }
                            </MudStack>
                            @if (t.Notes is not null)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">@t.Notes</MudText>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else
    {
        <MudTable T="ToolDto" Items="FilteredTools" Hover="true" Elevation="2"
                  SortLabel="Sort By" Filter="new Func<ToolDto, bool>(FilterFunc)">
            <ToolBarContent>
                <MudSpacer />
                <MudTextField @bind-Value="searchString" Placeholder="Search" Clearable="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ToolDto, object>(x => x.Name)">Tool</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ToolDto, object>(x => x.Category ?? string.Empty)">Category</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ToolDto, object>(x => x.Status.ToString())">Status</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ToolDto, object>(x => x.StorageLocationName ?? string.Empty)">Location</MudTableSortLabel></MudTh>
                <MudTh />
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        @if (context.Icon is not null)
                        {
                            <IconDisplay Icon="@context.Icon" Size="Size.Small" Color="Color.Primary" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Handyman" Size="Size.Small" Color="Color.Default" />
                        }
                        <MudText>@context.Name</MudText>
                    </MudStack>
                </MudTd>
                <MudTd><MudText Color="Color.Secondary">@(context.Category ?? "—")</MudText></MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">
                        @StatusLabel(context.Status, context.StatusNote)
                    </MudChip>
                </MudTd>
                <MudTd>
                    @if (context.StorageLocationName is not null)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Warehouse" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2">@context.StorageLocationName</MudText>
                        </MudStack>
                    }
                    else
                    {
                        <MudText Color="Color.Secondary">—</MudText>
                    }
                </MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                   OnClick="@(() => OpenEditDialog(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => DeleteTool(context.Id))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

@code {
    private List<ToolDto>? tools;
    private List<StorageLocationDto> locations = [];
    private Guid? locationFilter;
    private string searchString = "";
    private bool gridView = false;
    private Guid? dragging;
    private Guid? hovering;

    private bool FilterFunc(ToolDto t)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        if (t.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (t.Category?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (t.StorageLocationName?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (t.Notes?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    }

    private List<ToolDto> FilteredTools => locationFilter.HasValue
        ? (tools?.Where(t => t.StorageLocationId == locationFilter).ToList() ?? [])
        : (tools ?? []);

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        tools = await Sender.Send(new GetToolsQuery());
        locations = await Sender.Send(new GetStorageLocationsQuery());
    }

    private string CardStyle(Guid id)
    {
        if (id == dragging) return "opacity:0.4;cursor:grabbing;transition:opacity 0.15s;";
        if (id == hovering) return "outline:2px dashed #6B2737;outline-offset:3px;cursor:grab;";
        return "cursor:grab;";
    }

    private async Task Drop(Guid targetId)
    {
        if (dragging is null || dragging == targetId || tools is null) return;

        ToolDto? draggedItem = tools.FirstOrDefault(t => t.Id == dragging);
        if (draggedItem is null) return;

        int from = tools.IndexOf(draggedItem);
        int to   = tools.IndexOf(tools.First(t => t.Id == targetId));

        tools.RemoveAt(from);
        tools.Insert(to, draggedItem);

        dragging = null;
        hovering = null;

        await Sender.Send(new ReorderToolsCommand(tools.Select(t => t.Id).ToList()));
    }

    private static Color StatusColor(ToolStatus status) => status switch
    {
        ToolStatus.LentOut   => Color.Warning,
        ToolStatus.Borrowed  => Color.Info,
        ToolStatus.Rented    => Color.Secondary,
        ToolStatus.Required  => Color.Error,
        _                   => Color.Success
    };

    private static string StatusLabel(ToolStatus status, string? note) => status switch
    {
        ToolStatus.LentOut   => note is not null ? $"Lent to {note}" : "Lent out",
        ToolStatus.Borrowed  => note is not null ? $"Borrowed from {note}" : "Borrowed",
        ToolStatus.Rented    => note is not null ? $"Rented from {note}" : "Rented",
        ToolStatus.Required  => note is not null ? $"Required — {note}" : "Required",
        _                   => "Owned"
    };

    private async Task OpenAddDialog()
    {
        IDialogReference d = await DialogService.ShowAsync<AddToolDialog>("Add Tool");
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task OpenEditDialog(ToolDto tool)
    {
        DialogParameters<EditToolDialog> parameters = new();
        parameters.Add(x => x.Tool, tool);
        IDialogReference d = await DialogService.ShowAsync<EditToolDialog>("Edit Tool", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task DeleteTool(Guid id)
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync("Delete Tool",
            "Are you sure you want to delete this tool?", yesText: "Delete", cancelText: "Cancel");
        if (confirmed == true)
        {
            await Sender.Send(new DeleteToolCommand(id));
            await Load();
        }
    }
}
