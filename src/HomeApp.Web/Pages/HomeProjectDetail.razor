@page "/home-projects/{Id:guid}"
@inject ISender Sender
@inject IDialogService DialogService

@if (project is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudText Typo="Typo.h4">@project.Title</MudText>
            <MudChip T="string" Color="@StatusColor(project.Status)" Size="Size.Small">@project.Status</MudChip>
        </MudStack>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.SwapHoriz"
                   OnClick="OpenChangeStatusDialog">
            Change status
        </MudButton>
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(project.Description))
    {
        <MudPaper Elevation="1" Class="pa-4 mb-5">
            <MudText Typo="Typo.body1">@project.Description</MudText>
        </MudPaper>
    }

    <MudStack Row="true" Spacing="6" Wrap="Wrap.Wrap" Class="mb-6">
        @if (project.Budget.HasValue)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Payments" Color="Color.Secondary" />
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Budget</MudText>
                    <MudText Typo="Typo.body1">@($"{project.Budget.Value:N0} kr")</MudText>
                </div>
            </MudStack>
        }
        @if (project.StartDate.HasValue)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Color="Color.Secondary" />
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @(project.StartDate.Value > DateOnly.FromDateTime(DateTime.Today) ? "Starts" : "Started")
                    </MudText>
                    <MudText Typo="Typo.body1">@project.StartDate.Value.ToString("dd MMM yyyy")</MudText>
                </div>
            </MudStack>
        }
        @if (project.CompletedDate.HasValue)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Ended</MudText>
                    <MudText Typo="Typo.body1">@project.CompletedDate.Value.ToString("dd MMM yyyy")</MudText>
                </div>
            </MudStack>
        }
    </MudStack>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true">

        <MudTabPanel Text="Timeline" Icon="@Icons.Material.Filled.Timeline"
                     Style="padding: 24px; padding-top: 32px;">
            <MudPaper Elevation="1" Class="pa-4 mb-6">
                <MudText Typo="Typo.subtitle1" Class="mb-3">Add step</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="5">
                        <MudTextField @bind-Value="timelineTitle" Label="Title" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker @bind-Date="timelineDate" Label="Date (optional)" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="3" Class="d-flex align-end">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddTimelineEvent">
                            Add
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            @if (timelineEvents.Count == 0)
            {
                <MudText Color="Color.Secondary">No steps added yet.</MudText>
            }
            else
            {
                <MudTimeline TimelinePosition="TimelinePosition.Start">
                    @foreach (ProjectTimelineEventDto ev in timelineEvents)
                    {
                        <MudTimelineItem Color="@(ev.Date.HasValue ? Color.Primary : Color.Default)"
                                         Size="Size.Small"
                                         draggable="true"
                                         @ondragstart="@(() => timelineDragging = ev.Id)"
                                         @ondragend="@(() => { timelineDragging = null; timelineHovering = null; })"
                                         @ondragenter="@(() => timelineHovering = ev.Id)"
                                         @ondragover:preventDefault="true"
                                         @ondrop="@(() => TimelineDrop(ev.Id))"
                                         Style="@TimelineItemStyle(ev.Id)">
                            <ItemContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <div>
                                        <MudText Typo="Typo.body1">@ev.Title</MudText>
                                        @if (ev.Date.HasValue)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @ev.Date.Value.ToString("dd MMM yyyy")
                                            </MudText>
                                        }
                                    </div>
                                    <MudStack Row="true" Spacing="0">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                       Color="Color.Primary"
                                                       OnClick="@(() => OpenEditTimelineEventDialog(ev))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error"
                                                       OnClick="@(() => DeleteTimelineEvent(ev.Id))" />
                                    </MudStack>
                                </MudStack>
                            </ItemContent>
                        </MudTimelineItem>
                    }
                </MudTimeline>
            }
        </MudTabPanel>

        <MudTabPanel Text="Materials" Icon="@Icons.Material.Filled.Inventory"
                     Style="padding: 24px; padding-top: 32px;">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenAddMaterialDialog" Class="mb-5">
                Add Material
            </MudButton>

            @if (projectMaterials.Count == 0)
            {
                <MudText Color="Color.Secondary">No materials added yet.</MudText>
            }
            else
            {
                <MudTable T="ProjectMaterialDto" Items="projectMaterials" Hover="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>Material</MudTh>
                        <MudTh Style="text-align:right">Needed</MudTh>
                        <MudTh Style="text-align:right">In stock</MudTh>
                        <MudTh Style="text-align:center">Coverage</MudTh>
                        <MudTh />
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                @if (context.Icon is not null)
                                {
                                    <MudIcon Icon="@context.Icon" Size="Size.Small" Color="Color.Primary" />
                                }
                                <MudText>@context.Name</MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd Style="text-align:right">
                            @if (context.QuantityNeeded.HasValue)
                            {
                                <MudText>@context.QuantityNeeded.Value.ToString("G29") @context.Unit</MudText>
                            }
                            else
                            {
                                <MudText Color="Color.Secondary">—</MudText>
                            }
                        </MudTd>
                        <MudTd Style="text-align:right">
                            @if (context.QuantityInStock.HasValue)
                            {
                                <MudText>@context.QuantityInStock.Value.ToString("G29") @context.Unit</MudText>
                            }
                            else
                            {
                                <MudText Color="Color.Secondary">—</MudText>
                            }
                        </MudTd>
                        <MudTd Style="text-align:center">
                            @{ (string label, Color color) = StockCoverage(context); }
                            <MudChip T="string" Size="Size.Small" Color="@color">@label</MudChip>
                        </MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="@(() => OpenEditMaterialDialog(context))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => RemoveMaterial(context.MaterialId))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="Progress" Icon="@Icons.Material.Filled.TrendingUp"
                     Style="padding: 24px; padding-top: 32px;">
            <MudPaper Elevation="1" Class="pa-4 mb-6">
                <MudText Typo="Typo.subtitle1" Class="mb-3">Log progress</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker @bind-Date="progressDate" Label="Date" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="progressNote" Label="Note" />
                    </MudItem>
                    <MudItem xs="12" sm="2" Class="d-flex align-end">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddProgressEntry">
                            Add
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            @if (progressEntries.Count == 0)
            {
                <MudText Color="Color.Secondary">No progress logged yet.</MudText>
            }
            else
            {
                @foreach (ProgressEntryDto entry in progressEntries)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="3" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord"
                                 Size="Size.Small" Color="Color.Primary" Style="margin-top:4px" />
                        <div style="flex:1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @entry.Date.ToString("dd MMM yyyy")
                            </MudText>
                            <MudText>@entry.Note</MudText>
                        </div>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(() => DeleteProgressEntry(entry.Id))" />
                    </MudStack>
                    <MudDivider Class="mb-3" />
                }
            }
        </MudTabPanel>

        <MudTabPanel Text="Links" Icon="@Icons.Material.Filled.Link"
                     Style="padding: 24px; padding-top: 32px;">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenAddLinkDialog" Class="mb-5">
                Add Link
            </MudButton>

            @if (projectLinks.Count == 0)
            {
                <MudText Color="Color.Secondary">No links added yet.</MudText>
            }
            else
            {
                @foreach (ProjectLinkDto link in projectLinks)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Color="Color.Primary" />
                        <div style="flex:1">
                            <MudLink Href="@link.Url" Target="_blank" Typo="Typo.body1">@link.Label</MudLink>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@link.Url</MudText>
                        </div>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(() => DeleteLink(link.Id))" />
                    </MudStack>
                    <MudDivider Class="mb-3" />
                }
            }
        </MudTabPanel>

        <MudTabPanel Text="Contacts" Icon="@Icons.Material.Filled.Contacts"
                     Style="padding: 24px; padding-top: 32px;">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenAddContactDialog" Class="mb-5">
                Add Contact
            </MudButton>

            @if (projectContacts.Count == 0)
            {
                <MudText Color="Color.Secondary">No contacts added yet.</MudText>
            }
            else
            {
                <MudGrid>
                    @foreach (ProjectContactDto contact in projectContacts)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Row="true" AlignItems="AlignItems.Start"
                                              Justify="Justify.SpaceBetween">
                                        <div>
                                            <MudText Typo="Typo.subtitle1">@contact.Name</MudText>
                                            @if (contact.Role is not null)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                                         Class="ml-0 mt-1">
                                                    @contact.Role
                                                </MudChip>
                                            }
                                            @if (contact.Phone is not null)
                                            {
                                                <MudStack Row="true" AlignItems="AlignItems.Center"
                                                          Spacing="1" Class="mt-2">
                                                    <MudIcon Icon="@Icons.Material.Filled.Phone"
                                                             Size="Size.Small" Color="Color.Secondary" />
                                                    <MudText Typo="Typo.body2">@contact.Phone</MudText>
                                                </MudStack>
                                            }
                                        </div>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Size="Size.Small" Color="Color.Error"
                                                       OnClick="@(() => RemoveContact(contact.ContactId))" />
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudTabPanel>

    </MudTabs>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private HomeProjectDto? project;
    private List<ProjectMaterialDto> projectMaterials = [];
    private List<ProgressEntryDto> progressEntries = [];
    private List<ProjectLinkDto> projectLinks = [];
    private List<ProjectContactDto> projectContacts = [];
    private List<ProjectTimelineEventDto> timelineEvents = [];

    private DateTime? progressDate = DateTime.Today;
    private string progressNote = string.Empty;

    private string timelineTitle = string.Empty;
    private DateTime? timelineDate;
    private Guid? timelineDragging;
    private Guid? timelineHovering;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        project = await Sender.Send(new GetHomeProjectByIdQuery(Id));
        projectMaterials = await Sender.Send(new GetProjectMaterialsQuery(Id));
        progressEntries = await Sender.Send(new GetProjectProgressEntriesQuery(Id));
        projectLinks = await Sender.Send(new GetProjectLinksQuery(Id));
        projectContacts = await Sender.Send(new GetProjectContactsQuery(Id));
        timelineEvents = await Sender.Send(new GetProjectTimelineEventsQuery(Id));
    }

    private string TimelineItemStyle(Guid id)
    {
        if (id == timelineDragging) return "opacity:0.4;cursor:grabbing;";
        if (id == timelineHovering) return "outline:2px dashed #6B2737;outline-offset:3px;cursor:grab;";
        return "cursor:grab;";
    }

    private async Task TimelineDrop(Guid targetId)
    {
        if (timelineDragging is null || timelineDragging == targetId) return;

        ProjectTimelineEventDto? dragged = timelineEvents.FirstOrDefault(e => e.Id == timelineDragging);
        if (dragged is null) return;

        int from = timelineEvents.IndexOf(dragged);
        int to   = timelineEvents.IndexOf(timelineEvents.First(e => e.Id == targetId));

        timelineEvents.RemoveAt(from);
        timelineEvents.Insert(to, dragged);

        timelineDragging = null;
        timelineHovering = null;

        await Sender.Send(new ReorderTimelineEventsCommand(timelineEvents.Select(e => e.Id).ToList()));
    }

    private async Task AddTimelineEvent()
    {
        if (string.IsNullOrWhiteSpace(timelineTitle)) return;
        DateOnly? date = timelineDate.HasValue ? DateOnly.FromDateTime(timelineDate.Value) : null;
        await Sender.Send(new AddTimelineEventCommand(Id, timelineTitle, date));
        timelineTitle = string.Empty;
        timelineDate = null;
        await Load();
    }

    private async Task OpenEditTimelineEventDialog(ProjectTimelineEventDto ev)
    {
        DialogParameters<EditTimelineEventDialog> parameters = new();
        parameters.Add(x => x.EventId, ev.Id);
        parameters.Add(x => x.InitialTitle, ev.Title);
        parameters.Add(x => x.InitialDate, ev.Date);
        IDialogReference d = await DialogService.ShowAsync<EditTimelineEventDialog>("Edit step", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task DeleteTimelineEvent(Guid eventId)
    {
        await Sender.Send(new DeleteTimelineEventCommand(eventId));
        await Load();
    }

    private Color StatusColor(ProjectStatus status) => status switch
    {
        ProjectStatus.Planning    => Color.Info,
        ProjectStatus.InProgress  => Color.Warning,
        ProjectStatus.OnHold      => Color.Default,
        ProjectStatus.Completed   => Color.Success,
        ProjectStatus.Cancelled   => Color.Error,
        _                         => Color.Default
    };

    private (string Label, Color Color) StockCoverage(ProjectMaterialDto m)
    {
        if (m.QuantityNeeded is null)    return ("No estimate",    Color.Default);
        if (m.QuantityInStock is null)   return ("Stock unknown",  Color.Warning);
        if (m.QuantityInStock >= m.QuantityNeeded) return ("Covered", Color.Success);
        if (m.QuantityInStock > 0)
            return ($"{m.QuantityInStock:G29} of {m.QuantityNeeded:G29}", Color.Warning);
        return ("None in stock", Color.Error);
    }

    private async Task OpenChangeStatusDialog()
    {
        DialogParameters<ChangeStatusDialog> parameters = new();
        parameters.Add(x => x.ProjectId, Id);
        parameters.Add(x => x.CurrentStatus, project!.Status);
        IDialogReference d = await DialogService.ShowAsync<ChangeStatusDialog>("Change status", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task OpenAddMaterialDialog()
    {
        DialogParameters<AddMaterialToProjectDialog> parameters = new();
        parameters.Add(x => x.ProjectId, Id);
        parameters.Add(x => x.ExcludedIds, projectMaterials.Select(m => m.MaterialId).ToList());
        IDialogReference d = await DialogService.ShowAsync<AddMaterialToProjectDialog>("Add Material", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task OpenEditMaterialDialog(ProjectMaterialDto material)
    {
        DialogParameters<EditProjectMaterialDialog> parameters = new();
        parameters.Add(x => x.ProjectId, Id);
        parameters.Add(x => x.MaterialId, material.MaterialId);
        parameters.Add(x => x.QuantityNeeded, material.QuantityNeeded);
        parameters.Add(x => x.Unit, material.Unit);
        IDialogReference d = await DialogService.ShowAsync<EditProjectMaterialDialog>("Edit quantity", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task RemoveMaterial(Guid materialId)
    {
        await Sender.Send(new RemoveMaterialFromProjectCommand(Id, materialId));
        await Load();
    }

    private async Task AddProgressEntry()
    {
        if (string.IsNullOrWhiteSpace(progressNote)) return;
        DateOnly date = progressDate.HasValue
            ? DateOnly.FromDateTime(progressDate.Value)
            : DateOnly.FromDateTime(DateTime.Today);
        await Sender.Send(new AddProgressEntryCommand(Id, date, progressNote));
        progressNote = string.Empty;
        await Load();
    }

    private async Task DeleteProgressEntry(Guid entryId)
    {
        await Sender.Send(new DeleteProgressEntryCommand(entryId));
        await Load();
    }

    private async Task OpenAddLinkDialog()
    {
        DialogParameters<AddProjectLinkDialog> parameters = new();
        parameters.Add(x => x.ProjectId, Id);
        IDialogReference d = await DialogService.ShowAsync<AddProjectLinkDialog>("Add Link", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task DeleteLink(Guid linkId)
    {
        await Sender.Send(new RemoveProjectLinkCommand(linkId));
        await Load();
    }

    private async Task OpenAddContactDialog()
    {
        DialogParameters<AddContactToProjectDialog> parameters = new();
        parameters.Add(x => x.ProjectId, Id);
        IDialogReference d = await DialogService.ShowAsync<AddContactToProjectDialog>("Add Contact", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task RemoveContact(Guid contactId)
    {
        await Sender.Send(new RemoveContactFromProjectCommand(Id, contactId));
        await Load();
    }
}
