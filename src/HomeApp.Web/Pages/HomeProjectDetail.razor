@page "/home-projects/{Id:guid}"
@inject ISender Sender
@inject IDialogService DialogService
@inject IWebHostEnvironment Env

@if (project is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudStack Spacing="1" Class="mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudText Typo="Typo.h4">@project.Title</MudText>
            <MudChip T="string" Color="@StatusColor(project.Status)" Size="Size.Small">@project.Status</MudChip>
        </MudStack>
        <MudStack Row="true" Spacing="4" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center">
            @if (project.Budget.HasValue)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.Payments" Color="Color.Secondary" Size="Size.Small" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Budget</MudText>
                        <MudText Typo="Typo.body2">@($"{project.Budget.Value:N0} kr")</MudText>
                    </div>
                </MudStack>
            }
            @if (project.StartDate.HasValue)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Color="Color.Secondary" Size="Size.Small" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @(project.StartDate.Value > DateOnly.FromDateTime(DateTime.Today) ? "Starts" : "Started")
                        </MudText>
                        <MudText Typo="Typo.body2">@project.StartDate.Value.ToString("dd MMM yyyy")</MudText>
                    </div>
                </MudStack>
            }
            @if (project.CompletedDate.HasValue)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Ended</MudText>
                        <MudText Typo="Typo.body2">@project.CompletedDate.Value.ToString("dd MMM yyyy")</MudText>
                    </div>
                </MudStack>
            }
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.SwapHoriz"
                       Size="Size.Small" OnClick="OpenChangeStatusDialog">
                Change status
            </MudButton>
        </MudStack>
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(project.Description))
    {
        <MudPaper Elevation="1" Class="pa-4 mb-5">
            <MudText Typo="Typo.body1">@project.Description</MudText>
        </MudPaper>
    }

    <MudPaper Elevation="2" Class="mb-2 px-3 py-1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@ActiveTabIcon" Color="Color.Primary" />
            <MudSelect @bind-Value="activeTab" Dense="true" Margin="Margin.Dense"
                       Variant="Variant.Text" Style="font-weight:600;font-size:1rem;max-width:200px">
                <MudSelectItem Value="@("Timeline")">Timeline</MudSelectItem>
                <MudSelectItem Value="@("Notes")">Notes</MudSelectItem>
                <MudSelectItem Value="@("Materials")">Materials</MudSelectItem>
                <MudSelectItem Value="@("Tools")">Tools</MudSelectItem>
                <MudSelectItem Value="@("Progress")">Progress</MudSelectItem>
                <MudSelectItem Value="@("Expenses")">Expenses</MudSelectItem>
                <MudSelectItem Value="@("Photos")">Photos</MudSelectItem>
                <MudSelectItem Value="@("Links")">Links</MudSelectItem>
                <MudSelectItem Value="@("Contacts")">Contacts</MudSelectItem>
            </MudSelect>
        </MudStack>
    </MudPaper>

    <MudPaper Elevation="2">

        @if (activeTab == "Timeline")
        {
            <div style="padding: 24px; padding-top: 32px;">
                <MudPaper Elevation="1" Class="pa-4 mb-6">
                    <MudText Typo="Typo.subtitle1" Class="mb-3">Add step</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="5">
                            <MudTextField @bind-Value="timelineTitle" Label="Title" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudDatePicker @bind-Date="timelineDate" Label="Date (optional)" Clearable="true" />
                        </MudItem>
                        <MudItem xs="12" sm="3" Class="d-flex align-end">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddTimelineEvent">
                                Add
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                @if (timelineEvents.Count == 0)
                {
                    <MudText Color="Color.Secondary">No steps added yet.</MudText>
                }
                else
                {
                    <div class="mb-4">
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-1">
                            @timelineEvents.Count(e => e.IsCompleted) of @timelineEvents.Count steps done
                        </MudText>
                        <MudProgressLinear Value="@((double)timelineEvents.Count(e => e.IsCompleted) / timelineEvents.Count * 100)"
                                           Color="Color.Success" Rounded="true" Size="Size.Small" />
                    </div>

                    <MudTimeline TimelinePosition="TimelinePosition.Start">
                        @foreach (ProjectTimelineEventDto ev in timelineEvents)
                        {
                            <MudTimelineItem Color="@(ev.IsCompleted ? Color.Success : (ev.Date.HasValue ? Color.Primary : Color.Default))"
                                             Size="Size.Small"
                                             draggable="true"
                                             @ondragstart="@(() => timelineDragging = ev.Id)"
                                             @ondragend="@(() => { timelineDragging = null; timelineHovering = null; })"
                                             @ondragenter="@(() => timelineHovering = ev.Id)"
                                             @ondragover:preventDefault="true"
                                             @ondrop="@(() => TimelineDrop(ev.Id))"
                                             Style="@TimelineItemStyle(ev.Id)">
                                <ItemContent>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <div>
                                            <MudText Typo="Typo.body1"
                                                     Style="@(ev.IsCompleted ? "text-decoration:line-through;opacity:0.6" : string.Empty)">
                                                @ev.Title
                                            </MudText>
                                            @if (ev.Date.HasValue)
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @ev.Date.Value.ToString("dd MMM yyyy")
                                                </MudText>
                                            }
                                        </div>
                                        <MudStack Row="true" Spacing="0">
                                            <MudIconButton Icon="@(ev.IsCompleted ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.CheckCircle)"
                                                           Size="Size.Small" Color="Color.Success"
                                                           OnClick="@(() => ToggleTimelineEvent(ev.Id))" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                           Color="Color.Primary"
                                                           OnClick="@(() => OpenEditTimelineEventDialog(ev))" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                           Color="Color.Error"
                                                           OnClick="@(() => DeleteTimelineEvent(ev.Id))" />
                                        </MudStack>
                                    </MudStack>
                                </ItemContent>
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                }
            </div>
        }

        @if (activeTab == "Notes")
        {
            <div style="padding: 24px; padding-top: 32px;">
                @if (!showAddNoteForm)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                               OnClick="@(() => showAddNoteForm = true)" Class="mb-6">
                        Add Note
                    </MudButton>
                }
                else
                {
                    <MudPaper Elevation="1" Class="pa-4 mb-6">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">Add note</MudText>
                        <MudTextField @bind-Value="noteContent" Label="Note" Lines="3" Class="mb-3" />
                        @if (projectPhotos.Count > 0)
                        {
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Attach photos</MudText>
                            <MudGrid Class="mb-3">
                                @foreach (PhotoDto photo in projectPhotos)
                                {
                                    bool selected = newNotePhotoIds.Contains(photo.Id);
                                    <MudItem xs="3" sm="2">
                                        <div style="position:relative;cursor:pointer" @onclick="@(() => ToggleNewNotePhoto(photo.Id))">
                                            <img src="@($"/uploads/photos/{photo.StoredFileName}")"
                                                 style="width:100%;height:64px;object-fit:cover;border-radius:4px;
                                                        @(selected ? "outline:3px solid #6B2737;" : "opacity:0.5;")" />
                                            @if (selected)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary"
                                                         Style="position:absolute;top:2px;right:2px;background:white;border-radius:50%;font-size:18px" />
                                            }
                                        </div>
                                    </MudItem>
                                }
                            </MudGrid>
                        }
                        <MudStack Row="true" Spacing="2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddNote">Add</MudButton>
                            <MudButton Variant="Variant.Text" OnClick="CancelAddNote">Cancel</MudButton>
                        </MudStack>
                    </MudPaper>
                }

                @if (projectNotes.Count == 0)
                {
                    <MudText Color="Color.Secondary">No notes yet.</MudText>
                }
                else
                {
                    @foreach (ProjectNoteDto note in projectNotes)
                    {
                        <MudPaper Elevation="1" Class="pa-4 mb-4">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                <MudText Style="white-space:pre-wrap;flex:1">@note.Content</MudText>
                                <MudStack Row="true" Spacing="0">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                   Color="Color.Primary"
                                                   OnClick="@(() => OpenEditNoteDialog(note))" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="@(() => DeleteNote(note.Id))" />
                                </MudStack>
                            </MudStack>
                            @if (note.Photos.Count > 0)
                            {
                                <MudGrid Class="mt-3">
                                    @foreach (PhotoDto photo in note.Photos)
                                    {
                                        <MudItem xs="4" sm="3" md="2">
                                            <img src="@($"/uploads/photos/{photo.StoredFileName}")"
                                                 style="width:100%;height:80px;object-fit:cover;border-radius:4px;cursor:pointer"
                                                 @onclick="@(() => OpenPhotoViewer(photo))" />
                                        </MudItem>
                                    }
                                </MudGrid>
                            }
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                                @note.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                            </MudText>
                        </MudPaper>
                    }
                }
            </div>
        }

        @if (activeTab == "Materials")
        {
            <div style="padding: 24px; padding-top: 32px;">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenAddMaterialDialog" Class="mb-5">
                    Add Material
                </MudButton>

                @if (projectMaterials.Count == 0)
                {
                    <MudText Color="Color.Secondary">No materials added yet.</MudText>
                }
                else
                {
                    <MudTable T="ProjectMaterialDto" Items="projectMaterials" Hover="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Material</MudTh>
                            <MudTh Style="text-align:right">Needed</MudTh>
                            <MudTh Style="text-align:right">In stock</MudTh>
                            <MudTh Style="text-align:center">Coverage</MudTh>
                            <MudTh />
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    @if (context.Icon is not null)
                                    {
                                        <IconDisplay Icon="@context.Icon" Size="Size.Small" Color="Color.Primary" />
                                    }
                                    <MudText>@context.Name</MudText>
                                </MudStack>
                            </MudTd>
                            <MudTd Style="text-align:right">
                                @if (context.QuantityNeeded.HasValue)
                                {
                                    <MudText>@context.QuantityNeeded.Value.ToString("G29") @context.Unit</MudText>
                                }
                                else
                                {
                                    <MudText Color="Color.Secondary">—</MudText>
                                }
                            </MudTd>
                            <MudTd Style="text-align:right">
                                @if (context.QuantityInStock.HasValue)
                                {
                                    <MudText>@context.QuantityInStock.Value.ToString("G29") @context.Unit</MudText>
                                }
                                else
                                {
                                    <MudText Color="Color.Secondary">—</MudText>
                                }
                            </MudTd>
                            <MudTd Style="text-align:center">
                                @{ (string label, Color color) = StockCoverage(context); }
                                <MudChip T="string" Size="Size.Small" Color="@color">@label</MudChip>
                            </MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="@(() => OpenEditMaterialDialog(context))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => RemoveMaterial(context.MaterialId))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </div>
        }

        @if (activeTab == "Tools")
        {
            <div style="padding: 24px; padding-top: 32px;">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenAddToolDialog" Class="mb-5">
                    Add Tool
                </MudButton>

                @if (projectTools.Count == 0)
                {
                    <MudText Color="Color.Secondary">No tools added yet.</MudText>
                }
                else
                {
                    <MudTable T="HomeProjectToolDto" Items="projectTools" Hover="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Tool</MudTh>
                            <MudTh>Category</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh />
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    @if (context.Icon is not null)
                                    {
                                        <IconDisplay Icon="@context.Icon" Size="Size.Small" Color="Color.Primary" />
                                    }
                                    <MudText>@context.Name</MudText>
                                </MudStack>
                            </MudTd>
                            <MudTd>
                                <MudText Color="Color.Secondary">@(context.Category ?? "—")</MudText>
                            </MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="@ToolStatusColor(context.Status)">
                                    @ToolStatusLabel(context.Status, context.StatusNote)
                                </MudChip>
                            </MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => RemoveTool(context.ToolId))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </div>
        }

        @if (activeTab == "Progress")
        {
            <div style="padding: 24px; padding-top: 32px;">
                <MudPaper Elevation="1" Class="pa-4 mb-6">
                    <MudText Typo="Typo.subtitle1" Class="mb-3">Log progress</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="4">
                            <MudDatePicker @bind-Date="progressDate" Label="Date" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="progressNote" Label="Note" />
                        </MudItem>
                        <MudItem xs="12" sm="2" Class="d-flex align-end">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddProgressEntry">
                                Add
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                @if (progressEntries.Count == 0)
                {
                    <MudText Color="Color.Secondary">No progress logged yet.</MudText>
                }
                else
                {
                    @foreach (ProgressEntryDto entry in progressEntries)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="3" Class="mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord"
                                     Size="Size.Small" Color="Color.Primary" Style="margin-top:4px" />
                            <div style="flex:1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @entry.Date.ToString("dd MMM yyyy")
                                </MudText>
                                <MudText>@entry.Note</MudText>
                            </div>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => DeleteProgressEntry(entry.Id))" />
                        </MudStack>
                        <MudDivider Class="mb-3" />
                    }
                }
            </div>
        }

        @if (activeTab == "Expenses")
        {
            <div style="padding: 24px; padding-top: 32px;">
                <MudPaper Elevation="1" Class="pa-4 mb-6">
                    <MudText Typo="Typo.subtitle1" Class="mb-3">Add expense</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="expenseDescription" Label="Description" />
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudNumericField @bind-Value="expenseAmount" Label="Amount (kr)" Min="0" />
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudDatePicker @bind-Date="expenseDate" Label="Date" />
                        </MudItem>
                        <MudItem xs="12" sm="2" Class="d-flex align-end">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddExpense">
                                Add
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                @if (projectExpenses.Count == 0)
                {
                    <MudText Color="Color.Secondary">No expenses logged yet.</MudText>
                }
                else
                {
                    @if (project!.Budget.HasValue)
                    {
                        decimal totalSpent = projectExpenses.Sum(e => e.Amount);
                        decimal remaining = project.Budget.Value - totalSpent;
                        <MudStack Row="true" Spacing="4" Class="mb-5" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.body2">
                                Budget: <strong>@project.Budget.Value.ToString("N0") kr</strong>
                            </MudText>
                            <MudText Typo="Typo.body2">
                                Spent: <strong>@totalSpent.ToString("N0") kr</strong>
                            </MudText>
                            <MudText Typo="Typo.body2" Color="@(remaining < 0 ? Color.Error : Color.Success)">
                                Remaining: <strong>@remaining.ToString("N0") kr</strong>
                            </MudText>
                        </MudStack>
                    }

                    <MudTable T="ProjectExpenseDto" Items="projectExpenses" Hover="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Date</MudTh>
                            <MudTh>Description</MudTh>
                            <MudTh Style="text-align:right">Amount</MudTh>
                            <MudTh />
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Date.ToString("dd MMM yyyy")</MudTd>
                            <MudTd>@context.Description</MudTd>
                            <MudTd Style="text-align:right">@context.Amount.ToString("N0") kr</MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => DeleteExpense(context.Id))" />
                            </MudTd>
                        </RowTemplate>
                        <FooterContent>
                            <MudTd colspan="2"><strong>Total</strong></MudTd>
                            <MudTd Style="text-align:right"><strong>@projectExpenses.Sum(e => e.Amount).ToString("N0") kr</strong></MudTd>
                            <MudTd />
                        </FooterContent>
                    </MudTable>
                }
            </div>
        }

        @if (activeTab == "Photos")
        {
            <div style="padding: 24px; padding-top: 32px;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-5">
                    <MudFileUpload T="IReadOnlyList<IBrowserFile>" Accept=".jpg,.jpeg,.png,.webp"
                                   FilesChanged="UploadPhotos" @ref="fileUpload" Class="d-none" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Upload"
                               OnClick="@(() => fileUpload!.OpenFilePickerAsync())">
                        Upload Photos
                    </MudButton>
                    <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                        <MudIconButton Icon="@Icons.Material.Filled.GridView"
                                       Color="@(photoGridView ? Color.Primary : Color.Default)"
                                       OnClick="@(() => photoGridView = true)" />
                        <MudIconButton Icon="@Icons.Material.Filled.TableRows"
                                       Color="@(photoGridView ? Color.Default : Color.Primary)"
                                       OnClick="@(() => photoGridView = false)" />
                    </MudButtonGroup>
                </MudStack>

                @if (projectPhotos.Count == 0)
                {
                    <MudText Color="Color.Secondary">No photos yet.</MudText>
                }
                else if (photoGridView)
                {
                    <MudGrid>
                        @foreach (PhotoDto photo in projectPhotos)
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <MudCard Elevation="2">
                                    <div style="cursor:pointer" @onclick="@(() => OpenPhotoViewer(photo))">
                                        <MudCardMedia Image="@($"/uploads/photos/{photo.StoredFileName}")"
                                                      Height="200" />
                                    </div>
                                    <MudCardContent Class="pa-2">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @(photo.Caption ?? "No caption")
                                        </MudText>
                                    </MudCardContent>
                                    <MudCardActions>
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                       Color="Color.Primary"
                                                       OnClick="@(() => OpenEditCaptionDialog(photo))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error"
                                                       OnClick="@(() => DeletePhoto(photo.Id, photo.StoredFileName))" />
                                    </MudCardActions>
                                </MudCard>
                            </MudItem>
                        }
                    </MudGrid>
                }
                else
                {
                    <MudTable T="PhotoDto" Items="projectPhotos" Hover="true" Elevation="0">
                        <HeaderContent>
                            <MudTh></MudTh>
                            <MudTh>Caption</MudTh>
                            <MudTh>Uploaded</MudTh>
                            <MudTh />
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <img src="@($"/uploads/photos/{context.StoredFileName}")"
                                     style="width:64px;height:64px;object-fit:cover;border-radius:4px;cursor:pointer"
                                     @onclick="@(() => OpenPhotoViewer(context))" />
                            </MudTd>
                            <MudTd>@(context.Caption ?? "—")</MudTd>
                            <MudTd>@context.UploadedAt.ToLocalTime().ToString("dd MMM yyyy")</MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="@(() => OpenEditCaptionDialog(context))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => DeletePhoto(context.Id, context.StoredFileName))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </div>
        }

        @if (activeTab == "Links")
        {
            <div style="padding: 24px; padding-top: 32px;">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenAddLinkDialog" Class="mb-5">
                    Add Link
                </MudButton>

                @if (projectLinks.Count == 0)
                {
                    <MudText Color="Color.Secondary">No links added yet.</MudText>
                }
                else
                {
                    @foreach (ProjectLinkDto link in projectLinks)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Color="Color.Primary" />
                            <div style="flex:1">
                                <MudLink Href="@link.Url" Target="_blank" Typo="Typo.body1">@link.Label</MudLink>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@link.Url</MudText>
                            </div>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => DeleteLink(link.Id))" />
                        </MudStack>
                        <MudDivider Class="mb-3" />
                    }
                }
            </div>
        }

        @if (activeTab == "Contacts")
        {
            <div style="padding: 24px; padding-top: 32px;">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenAddContactDialog" Class="mb-5">
                    Add Contact
                </MudButton>

                @if (projectContacts.Count == 0)
                {
                    <MudText Color="Color.Secondary">No contacts added yet.</MudText>
                }
                else
                {
                    <MudGrid>
                        @foreach (ProjectContactDto contact in projectContacts)
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudStack Row="true" AlignItems="AlignItems.Start"
                                                  Justify="Justify.SpaceBetween">
                                            <div>
                                                <MudText Typo="Typo.subtitle1">@contact.Name</MudText>
                                                @if (contact.Role is not null)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                                             Class="ml-0 mt-1">
                                                        @contact.Role
                                                    </MudChip>
                                                }
                                                @if (contact.Phone is not null)
                                                {
                                                    <MudStack Row="true" AlignItems="AlignItems.Center"
                                                              Spacing="1" Class="mt-2">
                                                        <MudIcon Icon="@Icons.Material.Filled.Phone"
                                                                 Size="Size.Small" Color="Color.Secondary" />
                                                        <MudText Typo="Typo.body2">@contact.Phone</MudText>
                                                    </MudStack>
                                                }
                                            </div>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small" Color="Color.Error"
                                                           OnClick="@(() => RemoveContact(contact.ContactId))" />
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        }
                    </MudGrid>
                }
            </div>
        }

    </MudPaper>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private HomeProjectDto? project;
    private List<ProjectMaterialDto> projectMaterials = [];
    private List<ProgressEntryDto> progressEntries = [];
    private List<ProjectLinkDto> projectLinks = [];
    private List<ProjectContactDto> projectContacts = [];
    private List<ProjectTimelineEventDto> timelineEvents = [];
    private List<ProjectExpenseDto> projectExpenses = [];
    private List<PhotoDto> projectPhotos = [];
    private bool photoGridView = true;
    private MudFileUpload<IReadOnlyList<IBrowserFile>>? fileUpload;
    private List<ProjectNoteDto> projectNotes = [];
    private List<HomeProjectToolDto> projectTools = [];
    private string noteContent = string.Empty;
    private HashSet<Guid> newNotePhotoIds = [];
    private bool showAddNoteForm;

    private string activeTab = "Timeline";

    private string ActiveTabIcon => activeTab switch
    {
        "Timeline"  => Icons.Material.Filled.Timeline,
        "Notes"     => Icons.Material.Filled.StickyNote2,
        "Materials" => Icons.Material.Filled.Inventory,
        "Tools"     => Icons.Material.Filled.Handyman,
        "Progress"  => Icons.Material.Filled.TrendingUp,
        "Expenses"  => Icons.Material.Filled.Receipt,
        "Photos"    => Icons.Material.Filled.PhotoLibrary,
        "Links"     => Icons.Material.Filled.Link,
        "Contacts"  => Icons.Material.Filled.Contacts,
        _           => Icons.Material.Filled.Dashboard
    };

    private DateTime? progressDate = DateTime.Today;
    private string progressNote = string.Empty;

    private string timelineTitle = string.Empty;
    private DateTime? timelineDate;
    private Guid? timelineDragging;
    private Guid? timelineHovering;

    private string expenseDescription = string.Empty;
    private decimal? expenseAmount;
    private DateTime? expenseDate = DateTime.Today;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        project = await Sender.Send(new GetHomeProjectByIdQuery(Id));
        projectMaterials = await Sender.Send(new GetProjectMaterialsQuery(Id));
        progressEntries = await Sender.Send(new GetProjectProgressEntriesQuery(Id));
        projectLinks = await Sender.Send(new GetProjectLinksQuery(Id));
        projectContacts = await Sender.Send(new GetProjectContactsQuery(Id));
        timelineEvents = await Sender.Send(new GetProjectTimelineEventsQuery(Id));
        projectExpenses = await Sender.Send(new GetProjectExpensesQuery(Id));
        projectPhotos = await Sender.Send(new GetProjectPhotosQuery(Id));
        projectNotes = await Sender.Send(new GetProjectNotesQuery(Id));
        projectTools = await Sender.Send(new GetProjectToolsQuery(Id));
    }

    private string TimelineItemStyle(Guid id)
    {
        if (id == timelineDragging) return "opacity:0.4;cursor:grabbing;";
        if (id == timelineHovering) return "outline:2px dashed #6B2737;outline-offset:3px;cursor:grab;";
        return "cursor:grab;";
    }

    private async Task TimelineDrop(Guid targetId)
    {
        if (timelineDragging is null || timelineDragging == targetId) return;

        ProjectTimelineEventDto? dragged = timelineEvents.FirstOrDefault(e => e.Id == timelineDragging);
        if (dragged is null) return;

        int from = timelineEvents.IndexOf(dragged);
        int to   = timelineEvents.IndexOf(timelineEvents.First(e => e.Id == targetId));

        timelineEvents.RemoveAt(from);
        timelineEvents.Insert(to, dragged);

        timelineDragging = null;
        timelineHovering = null;

        await Sender.Send(new ReorderTimelineEventsCommand(timelineEvents.Select(e => e.Id).ToList()));
    }

    private async Task AddTimelineEvent()
    {
        if (string.IsNullOrWhiteSpace(timelineTitle)) return;
        DateOnly? date = timelineDate.HasValue ? DateOnly.FromDateTime(timelineDate.Value) : null;
        await Sender.Send(new AddTimelineEventCommand(Id, timelineTitle, date));
        timelineTitle = string.Empty;
        timelineDate = null;
        await Load();
    }

    private async Task OpenEditTimelineEventDialog(ProjectTimelineEventDto ev)
    {
        DialogParameters<EditTimelineEventDialog> parameters = new();
        parameters.Add(x => x.EventId, ev.Id);
        parameters.Add(x => x.InitialTitle, ev.Title);
        parameters.Add(x => x.InitialDate, ev.Date);
        IDialogReference d = await DialogService.ShowAsync<EditTimelineEventDialog>("Edit step", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task ToggleTimelineEvent(Guid eventId)
    {
        await Sender.Send(new ToggleTimelineEventCompletionCommand(eventId));
        await Load();
    }

    private async Task DeleteTimelineEvent(Guid eventId)
    {
        await Sender.Send(new DeleteTimelineEventCommand(eventId));
        await Load();
    }

    private async Task AddExpense()
    {
        if (string.IsNullOrWhiteSpace(expenseDescription) || expenseAmount is null or <= 0) return;
        DateOnly date = expenseDate.HasValue
            ? DateOnly.FromDateTime(expenseDate.Value)
            : DateOnly.FromDateTime(DateTime.Today);
        await Sender.Send(new AddProjectExpenseCommand(Id, expenseDescription, expenseAmount.Value, date));
        expenseDescription = string.Empty;
        expenseAmount = null;
        expenseDate = DateTime.Today;
        await Load();
    }

    private async Task DeleteExpense(Guid expenseId)
    {
        await Sender.Send(new DeleteProjectExpenseCommand(expenseId));
        await Load();
    }

    private async Task UploadPhotos(IReadOnlyList<IBrowserFile> files)
    {
        string webRoot = Env.WebRootPath ?? Path.Combine(Env.ContentRootPath, "wwwroot");
        string uploadDir = Path.Combine(webRoot, "uploads", "photos");
        Directory.CreateDirectory(uploadDir);

        foreach (IBrowserFile file in files)
        {
            string storedFileName = $"{Guid.NewGuid()}{Path.GetExtension(file.Name)}";
            string uploadPath = Path.Combine(uploadDir, storedFileName);

            await using FileStream fs = new(uploadPath, FileMode.Create);
            await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(fs);

            await Sender.Send(new AddPhotoCommand(Id, file.Name, storedFileName, null));
        }

        await Load();
    }

    private void ToggleNewNotePhoto(Guid id)
    {
        if (!newNotePhotoIds.Add(id))
            newNotePhotoIds.Remove(id);
    }

    private async Task AddNote()
    {
        if (string.IsNullOrWhiteSpace(noteContent)) return;
        await Sender.Send(new AddProjectNoteCommand(Id, noteContent, [..newNotePhotoIds]));
        noteContent = string.Empty;
        newNotePhotoIds.Clear();
        showAddNoteForm = false;
        await Load();
    }

    private void CancelAddNote()
    {
        noteContent = string.Empty;
        newNotePhotoIds.Clear();
        showAddNoteForm = false;
    }

    private async Task OpenEditNoteDialog(ProjectNoteDto note)
    {
        DialogParameters<EditProjectNoteDialog> parameters = new();
        parameters.Add(x => x.NoteId, note.Id);
        parameters.Add(x => x.InitialContent, note.Content);
        parameters.Add(x => x.InitialPhotoIds, note.Photos.Select(p => p.Id).ToList());
        parameters.Add(x => x.AvailablePhotos, projectPhotos);
        IDialogReference d = await DialogService.ShowAsync<EditProjectNoteDialog>("Edit note", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task DeleteNote(Guid noteId)
    {
        await Sender.Send(new DeleteProjectNoteCommand(noteId));
        await Load();
    }

    private async Task OpenPhotoViewer(PhotoDto photo)
    {
        DialogParameters<PhotoViewerDialog> parameters = new();
        parameters.Add(x => x.StoredFileName, photo.StoredFileName);
        parameters.Add(x => x.Caption, photo.Caption);
        await DialogService.ShowAsync<PhotoViewerDialog>(string.Empty, parameters,
            new DialogOptions { MaxWidth = MaxWidth.ExtraExtraLarge, CloseButton = true });
    }

    private async Task OpenEditCaptionDialog(PhotoDto photo)
    {
        DialogParameters<EditPhotoCaptionDialog> parameters = new();
        parameters.Add(x => x.PhotoId, photo.Id);
        parameters.Add(x => x.InitialCaption, photo.Caption);
        IDialogReference d = await DialogService.ShowAsync<EditPhotoCaptionDialog>("Edit caption", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task DeletePhoto(Guid photoId, string storedFileName)
    {
        await Sender.Send(new DeletePhotoCommand(photoId));

        string webRoot = Env.WebRootPath ?? Path.Combine(Env.ContentRootPath, "wwwroot");
        string filePath = Path.Combine(webRoot, "uploads", "photos", storedFileName);
        if (File.Exists(filePath))
            File.Delete(filePath);

        await Load();
    }

    private Color StatusColor(ProjectStatus status) => status switch
    {
        ProjectStatus.Planning    => Color.Info,
        ProjectStatus.InProgress  => Color.Warning,
        ProjectStatus.OnHold      => Color.Default,
        ProjectStatus.Completed   => Color.Success,
        ProjectStatus.Cancelled   => Color.Error,
        _                         => Color.Default
    };

    private (string Label, Color Color) StockCoverage(ProjectMaterialDto m)
    {
        if (m.QuantityNeeded is null)    return ("No estimate",    Color.Default);
        if (m.QuantityInStock is null)   return ("Stock unknown",  Color.Warning);
        if (m.QuantityInStock >= m.QuantityNeeded) return ("Covered", Color.Success);
        if (m.QuantityInStock > 0)
            return ($"{m.QuantityInStock:G29} of {m.QuantityNeeded:G29}", Color.Warning);
        return ("None in stock", Color.Error);
    }

    private async Task OpenChangeStatusDialog()
    {
        DialogParameters<ChangeStatusDialog> parameters = new();
        parameters.Add(x => x.ProjectId, Id);
        parameters.Add(x => x.CurrentStatus, project!.Status);
        IDialogReference d = await DialogService.ShowAsync<ChangeStatusDialog>("Change status", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task OpenAddMaterialDialog()
    {
        DialogParameters<AddMaterialToProjectDialog> parameters = new();
        parameters.Add(x => x.ProjectId, Id);
        parameters.Add(x => x.ExcludedIds, projectMaterials.Select(m => m.MaterialId).ToList());
        IDialogReference d = await DialogService.ShowAsync<AddMaterialToProjectDialog>("Add Material", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task OpenEditMaterialDialog(ProjectMaterialDto material)
    {
        DialogParameters<EditProjectMaterialDialog> parameters = new();
        parameters.Add(x => x.ProjectId, Id);
        parameters.Add(x => x.MaterialId, material.MaterialId);
        parameters.Add(x => x.QuantityNeeded, material.QuantityNeeded);
        parameters.Add(x => x.Unit, material.Unit);
        IDialogReference d = await DialogService.ShowAsync<EditProjectMaterialDialog>("Edit quantity", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task RemoveMaterial(Guid materialId)
    {
        await Sender.Send(new RemoveMaterialFromProjectCommand(Id, materialId));
        await Load();
    }

    private async Task OpenAddToolDialog()
    {
        DialogParameters<AddToolToProjectDialog> parameters = new();
        parameters.Add(x => x.ProjectId, Id);
        parameters.Add(x => x.ExcludedIds, projectTools.Select(t => t.ToolId).ToList());
        IDialogReference d = await DialogService.ShowAsync<AddToolToProjectDialog>("Add Tool", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task RemoveTool(Guid toolId)
    {
        await Sender.Send(new RemoveToolFromProjectCommand(Id, toolId));
        await Load();
    }

    private static Color ToolStatusColor(ToolStatus status) => status switch
    {
        ToolStatus.LentOut  => Color.Warning,
        ToolStatus.Borrowed => Color.Info,
        ToolStatus.Rented   => Color.Secondary,
        _                   => Color.Success
    };

    private static string ToolStatusLabel(ToolStatus status, string? note) => status switch
    {
        ToolStatus.LentOut  => note is not null ? $"Lent to {note}" : "Lent out",
        ToolStatus.Borrowed => note is not null ? $"Borrowed from {note}" : "Borrowed",
        ToolStatus.Rented   => note is not null ? $"Rented from {note}" : "Rented",
        _                   => "Owned"
    };

    private async Task AddProgressEntry()
    {
        if (string.IsNullOrWhiteSpace(progressNote)) return;
        DateOnly date = progressDate.HasValue
            ? DateOnly.FromDateTime(progressDate.Value)
            : DateOnly.FromDateTime(DateTime.Today);
        await Sender.Send(new AddProgressEntryCommand(Id, date, progressNote));
        progressNote = string.Empty;
        await Load();
    }

    private async Task DeleteProgressEntry(Guid entryId)
    {
        await Sender.Send(new DeleteProgressEntryCommand(entryId));
        await Load();
    }

    private async Task OpenAddLinkDialog()
    {
        DialogParameters<AddProjectLinkDialog> parameters = new();
        parameters.Add(x => x.ProjectId, Id);
        IDialogReference d = await DialogService.ShowAsync<AddProjectLinkDialog>("Add Link", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task DeleteLink(Guid linkId)
    {
        await Sender.Send(new RemoveProjectLinkCommand(linkId));
        await Load();
    }

    private async Task OpenAddContactDialog()
    {
        DialogParameters<AddContactToProjectDialog> parameters = new();
        parameters.Add(x => x.ProjectId, Id);
        IDialogReference d = await DialogService.ShowAsync<AddContactToProjectDialog>("Add Contact", parameters);
        DialogResult? r = await d.Result;
        if (r is { Canceled: false }) await Load();
    }

    private async Task RemoveContact(Guid contactId)
    {
        await Sender.Send(new RemoveContactFromProjectCommand(Id, contactId));
        await Load();
    }
