@page "/shopping-list"
@inject ISender Sender
@inject IJSRuntime JS

<MudText Typo="Typo.h4" Class="mb-2">Shopping List</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
    Materials needed across all projects where stock falls short.
</MudText>

@if (items is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (items.Count == 0)
{
    <MudAlert Severity="Severity.Success">
        All project materials are covered by current stock — nothing to buy.
    </MudAlert>
}
else
{
    <MudButton StartIcon="@(copied ? Icons.Material.Filled.Check : Icons.Material.Filled.ContentCopy)"
               Color="@(copied ? Color.Success : Color.Default)"
               Variant="Variant.Outlined"
               Size="Size.Small"
               Class="mb-4"
               OnClick="CopyToClipboard">
        @(copied ? "Copied!" : "Copy list")
    </MudButton>

    <MudTable T="ShoppingListItemDto" Items="items" Hover="true" Elevation="2" Class="mb-6">
        <HeaderContent>
            <MudTh>Material</MudTh>
            <MudTh Style="text-align:right">Needed</MudTh>
            <MudTh Style="text-align:right">In stock</MudTh>
            <MudTh Style="text-align:right">To buy</MudTh>
            <MudTh Style="text-align:right">Est. cost</MudTh>
            <MudTh>Projects</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudText Typo="Typo.body1">@context.Name</MudText>
                @if (context.Unit is not null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Unit</MudText>
                }
            </MudTd>
            <MudTd Style="text-align:right">@context.TotalNeeded.ToString("G29")</MudTd>
            <MudTd Style="text-align:right">@(context.InStock?.ToString("G29") ?? "—")</MudTd>
            <MudTd Style="text-align:right">
                <MudText Color="Color.Error"><strong>@context.Shortfall.ToString("G29")</strong></MudText>
            </MudTd>
            <MudTd Style="text-align:right">
                @if (context.EstimatedCost.HasValue)
                {
                    <MudText Typo="Typo.body2">@context.EstimatedCost.Value.ToString("N0") kr</MudText>
                }
                else
                {
                    <MudText Color="Color.Secondary">—</MudText>
                }
            </MudTd>
            <MudTd>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (string proj in context.ProjectNames)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">@proj</MudChip>
                    }
                </MudStack>
            </MudTd>
        </RowTemplate>
        <FooterContent>
            <MudTd colspan="3"><strong>@items.Count item@(items.Count == 1 ? string.Empty : "s") to buy</strong></MudTd>
            <MudTd Style="text-align:right">
                @if (items.Any(i => i.EstimatedCost.HasValue))
                {
                    <strong>@items.Where(i => i.EstimatedCost.HasValue).Sum(i => i.EstimatedCost!.Value).ToString("N0") kr</strong>
                }
            </MudTd>
            <MudTd />
        </FooterContent>
    </MudTable>
}

@code {
    private List<ShoppingListItemDto>? items;
    private bool copied;

    protected override async Task OnInitializedAsync()
    {
        items = await Sender.Send(new GetShoppingListQuery());
    }

    private async Task CopyToClipboard()
    {
        if (items is null || items.Count == 0) return;

        var lines = new System.Text.StringBuilder();
        lines.AppendLine($"Shopping List — {DateTime.Today:dd MMM yyyy}");
        lines.AppendLine();
        foreach (ShoppingListItemDto item in items)
        {
            string amount = item.Unit is not null
                ? $"{item.Shortfall.ToString("G29")} {item.Unit}"
                : item.Shortfall.ToString("G29");
            string projects = string.Join(", ", item.ProjectNames);
            string cost = item.EstimatedCost.HasValue ? $"  ~{item.EstimatedCost.Value:N0} kr" : string.Empty;
            lines.AppendLine($"☐ {item.Name} — {amount}  ({projects}){cost}");
        }

        await JS.InvokeVoidAsync("copyToClipboard", lines.ToString());
        copied = true;
        StateHasChanged();
        await Task.Delay(2000);
        copied = false;
    }
}
